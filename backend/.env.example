# Blue Team Trainer - Backend Config
# Copy this file to `.env` and fill in the values.

# ---- Victim VM connection ----
VICTIM_HOST=192.168.56.10          # IP or hostname of the Windows victim VM
VICTIM_USER=atomicuser              # Local account used for WinRM
VICTIM_PASS=ChangeMe_StrongPass123! # Must match the password set by victim-setup.ps1

# ---- WinRM transport ----
WINRM_TRANSPORT=ntlm                # ntlm | basic | kerberos | credssp | certificate
WINRM_PORT=5985                     # 5985 = HTTP, 5986 = HTTPS
WINRM_TIMEOUT=300                   # seconds

# ---- Backend bind ----
BIND_HOST=0.0.0.0
BIND_PORT=8000

# ---- CORS ----
# Use '*' for local development only. For shared deployments, lock this down.
ALLOWED_ORIGINS=*
